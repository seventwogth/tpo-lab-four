          <JSR223PostProcessor guiclass="TestBeanGUI" testclass="JSR223PostProcessor" testname="Stop Test On First HTTP 503" enabled="true">
            <stringProp name="scriptLanguage">groovy</stringProp>
            <stringProp name="parameters"></stringProp>
            <stringProp name="filename"></stringProp>
            <stringProp name="cacheKey">true</stringProp>
            <stringProp name="script">if (prev != null &amp;&amp; prev.getResponseCode() == &#x27;503&#x27;) {
    log.warn(&#x27;HTTP 503 detected, stopping test immediately&#x27;)
    ctx.getEngine().stopTest(false)
}</stringProp>
